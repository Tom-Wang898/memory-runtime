#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
source "${SCRIPT_DIR}/_resolve-node.sh"
NODE_BIN="$(resolve_memory_runtime_node)"

LOG_DIR="${HOME}/.memory-runtime/logs"
mkdir -p "${LOG_DIR}"
LOG_FILE="${LOG_DIR}/memory-runtime-mcp-debug.log"

{
  printf '\n[%s] starting memory-runtime-mcp-debug\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
  printf 'node=%s\n' "${NODE_BIN}"
  printf 'pwd=%s\n' "${PWD}"
  printf 'path=%s\n' "${PATH:-}"
} >> "${LOG_FILE}"

exec "${NODE_BIN}" \
  --disable-warning=ExperimentalWarning \
  --experimental-strip-types \
  --import "${PROJECT_ROOT}/scripts/register-ts-loader.mjs" \
  "${PROJECT_ROOT}/scripts/memory-runtime-mcp.ts" \
  2>> "${LOG_FILE}"

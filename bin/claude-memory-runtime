#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
source "${SCRIPT_DIR}/_resolve-node.sh"
NODE_BIN="$(resolve_memory_runtime_node)"

exec "${NODE_BIN}" "${PROJECT_ROOT}/scripts/claude-wrapper.mjs" "$@"

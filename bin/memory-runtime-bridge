#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

exec node \
  --disable-warning=ExperimentalWarning \
  --experimental-strip-types \
  --import "${PROJECT_ROOT}/scripts/register-ts-loader.mjs" \
  "${PROJECT_ROOT}/scripts/memory-runtime-bridge.ts"
